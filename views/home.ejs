<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/output.css" />
    <title>URL Shortener</title>
  </head>
  <body class="min-h-screen bg-indigo-100 flex items-center justify-center p-6">
    <div class="w-full max-w-[80%] bg-white rounded-2xl shadow-2xl p-10">
      <h1 class="text-5xl font-extrabold text-center text-violet-700">
        URL Shortener
      </h1>

      <% if (locals.user) { %>
        <div class="mt-4 flex flex-col items-center gap-3 text-lg font-semibold text-violet-600 sm:flex-row sm:justify-center">
          <span>
            <% if (user.role === "ADMIN") { %>
              Hello Admin
            <% } else { %>
              Hello <%= user.name %>
            <% } %>
          </span>

          <a
            href="/user/logout"
            class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700 hover:bg-gray-200"
          >
            Logout
          </a>
        </div>
      <% } %>

      <form action="/url" method="POST" class="mt-8 space-y-6">
        <div>
          <label class="block text-gray-700 font-semibold mb-2">
            Enter your URL
          </label>

          <input
            type="url"
            name="url"
            placeholder="https://example.com"
            required
            class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:border-violet-500 focus:ring-4 focus:ring-violet-200 outline-none text-lg"
          />
        </div>

        <button
          class="w-full bg-violet-600 hover:bg-violet-700 duration-300 text-white text-lg font-bold py-4 rounded-xl shadow-lg hover:shadow-xl cursor-pointer"
        >
          Generate Short URL
        </button>
      </form>

      <% if (locals.id) { %>
        <div class="mt-8 bg-green-50 border border-green-300 rounded-xl p-5">
          <h2 class="font-bold text-green-700 text-lg mb-2">
            Your Short URL
          </h2>

          <a
            href="<%= locals.shortUrl %>"
            class="text-violet-600 underline break-all text-lg"
          >
            <%= locals.shortUrl %>
          </a>
        </div>
      <% } %>

     <div class="mt-10">
        <% if(locals.urls){ %>
            <h2 class="text-2xl font-bold text-violet-700 mb-4">
              <% if (user && user.role === "ADMIN") { %>
                All Recent URLs
              <% } else { %>
                Your Short URLs
              <% } %>
            </h2>
            <div class="overflow-x-auto rounded-xl border border-gray-200">
              <table class="w-full">
                <thead class="bg-violet-600 text-white">
                  <tr>
                    <th class="px-4 py-3 text-left font-semibold">S.no</th>
                    <th class="px-4 py-3 text-left font-semibold">Short ID</th>
                    <th class="px-4 py-3 text-left font-semibold">Redirect</th>
                    <th class="px-4 py-3 text-left font-semibold">Clicks</th>
                    <% if (user && user.role === "ADMIN") { %>
                      <th class="px-4 py-3 text-left font-semibold">Created By</th>
                    <% } %>
                    <th class="px-4 py-3 text-left font-semibold">Action</th>
                  </tr>
                </thead>
                <tbody>
                <% urls.forEach((url, index) => { %>
                    <tr class="border-b border-gray-200 hover:bg-gray-50 transition">
                        <td class="px-4 py-3 text-gray-800">
                            <%= index + 1 %>
                        </td>
                        <td class="px-4 py-3">
                            <span class="bg-blue-600 text-white px-3 py-1 rounded-lg font-semibold">
                              <%= url.shortId %>
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <a href="<%= url.redirectURL %>" target="_blank" class="text-violet-600 hover:text-violet-800 underline break-all">
                              <%= url.redirectURL %>
                            </a>
                        </td>
                        <td class="px-4 py-3">
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-lg font-semibold">
                              <%= url.visitHistory.length %>
                            </span>
                        </td>
                        <% if (user && user.role === "ADMIN") { %>
                          <td class="px-4 py-3">
                            <div class="text-sm text-gray-700">
                              <% if (url.createdby) { %>
                                <p class="font-semibold"><%= url.createdby.name %></p>
                                <p class="text-gray-600"><%= url.createdby.email %></p>
                              <% } else { %>
                                <p class="font-semibold">Unknown user</p>
                                <p class="text-gray-600">No owner saved</p>
                              <% } %>
                            </div>
                          </td>
                        <% } %>
                        <td class="px-4 py-3">
                            <button onclick="copyURL('/<%= url.shortId %>')" class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded-lg font-semibold">
                              Copy
                            </button>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
        <% } %>
    </div>
     
    </div>
    
    <script src="/js/copy.js"></script>
  </body>
</html>
